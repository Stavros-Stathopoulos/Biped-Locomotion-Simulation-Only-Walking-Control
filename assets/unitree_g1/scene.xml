<mujoco model="g1 scene">
  <include file="g1_29dof.xml"/>

  <statistic center="0.0 0.0 0.8" extent="12"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat" rgb1="0 0 0" rgb2="0 0 0" width="512" height="3072"/>
    <!-- Procedural grid texture for spatial reference during walking -->
    <texture type="2d" name="grid" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" width="300" height="300" mark="edge" markrgb="0.2 0.3 0.4"/>
    <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="1 0 3.5" dir="0 0 -1" directional="true"/>
    
    <!-- The physical ground plane MUST be here -->
    <geom name="ground_plane" type="plane" size="0 0 0.05" material="grid" condim="3" friction="1 0.005 0.0001"/>
    
    <!-- The tracking camera -->
    <camera name="track_com_cam" mode="trackcom" pos="0 -3 0.5" xyaxes="1 0 0 0 0 1"/>
  </worldbody>
</mujoco>