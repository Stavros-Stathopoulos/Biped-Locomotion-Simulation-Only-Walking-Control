<mujoco model="g1 scene tilted">
  <include file="g1_29dof.xml"/>

  <statistic center="1.0 0.7 1.0" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat" rgb1="0 0 0" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="tilt_tex" builtin="checker" rgb1="0.25 0.3 0.2" rgb2="0.15 0.2 0.12" width="300" height="300"/>
    <material name="tilt_mat" texture="tilt_tex" texuniform="true" texrepeat="5 5" reflectance="0.15"/>
  </asset>

  <worldbody>
    <light pos="1 0 3.5" dir="0 0 -1" directional="true"/>

    <!-- Tilted plane: ~3 degrees slope along the X axis -->
    <geom name="tilted_floor" type="plane" size="5 5 0.05"
          euler="3 0 0" pos="1.0 0 0"
          material="tilt_mat" friction="1.0 0.005 0.0001" group="2"/>
  </worldbody>
</mujoco>
